# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Image Generation (fal.ai) - optional, falls back to Unsplash
FAL_API_KEY=your_fal_api_key_here

# Unsplash (free stock photos) - optional fallback
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Chrome profile directory (persistent login)
CHROME_USER_DATA_DIR=./storage/chrome_profiles

# Database
DB_PATH=./storage/app.db

# Posting settings
POST_INTERVAL_MIN=7
POST_INTERVAL_MAX=10
FORBIDDEN_HOURS_START=0
FORBIDDEN_HOURS_END=7
IMAGE_COUNT=6
TARGET_CHAR_COUNT=2000
